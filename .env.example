# ─────────────────────────────────────────────────────────────────────────────
# CyberKeep — Muhit O'zgaruvchilari (namuna)
# Bu faylni .env deb nusxa ko'chiring va qiymatlarni to'ldiring.
# .env faylini GIT'ga HECH QACHON qo'shmang!
# ─────────────────────────────────────────────────────────────────────────────

# Telegram Bot Token (@BotFather dan olasiz)
BOT_TOKEN=1234567890:AABBccDDeeffGGhhIIjjKKllMMnnOOppQQrr

# Sizning Telegram ID ingiz (admin panel uchun)
# ID ni bilish: @userinfobot ga /start yuboring
ADMIN_ID=123456789

# PostgreSQL URL (Railway avtomatik beradi DATABASE_URL nomida)
# Lokal uchun: postgresql+asyncpg://user:password@localhost:5432/cyberkeep
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Server Pepper — 32 baytlik tasodifiy string
# Generatsiya: python -c "import secrets; print(secrets.token_hex(32))"
# BU QIYMATNI HECH QACHON O'ZGARTIRMANG — o'zgarsa barcha hashlar bekor bo'ladi!
SERVER_PEPPER=your_64_char_hex_string_here_generate_with_python

# Ixtiyoriy sozlamalar (default qiymatlar ko'rsatilgan)
FREE_PASSWORD_LIMIT=5
FREE_FILE_LIMIT=2
SESSION_TIMEOUT=600
BURNER_LINK_TTL=86400
